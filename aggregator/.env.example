# ─────────────────────────────────────────────────────────────────────────────
# OTC Signal Aggregator Bot – Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, copy the token here.
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Data APIs ─────────────────────────────────────────────────────────────────
# NewsAPI – https://newsapi.org (free: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# NOTE: Fundamentals are now sourced via the 'ecocal' library (Forex Factory
# economic calendar). No API key is required for this module.

# ── Pocket Option WebSocket (optional) ───────────────────────────────────────
# Your Pocket Option ci_session cookie value (URL-encoded).
# How to get it:
#   1. Log into Pocket Option in Chrome
#   2. Open DevTools (F12) → Application → Cookies → https://pocketoption.com
#   3. Find the cookie named 'ci_session' and copy its value
# If left empty, the WebSocket/technical module is skipped.
# Fundamentals + news + social still work without it.
POCKET_CI_SESSION=

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# Seconds between full scan cycles (default: 900 = 15 minutes)
SCAN_INTERVAL_SECONDS=900

# Seconds to suppress duplicate signals for the same asset (default: 60)
SIGNAL_COOLDOWN_SECONDS=60
