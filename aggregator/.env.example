# ─────────────────────────────────────────────────────────────────────────────
# OTC Signal Aggregator Bot – Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, copy the token here.
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Data APIs ─────────────────────────────────────────────────────────────────
# Finnworlds macro calendar – https://finnworlds.com
FINNWORLDS_KEY=your_finnworlds_key_here

# NewsAPI – https://newsapi.org (free: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# ── Pocket Option WebSocket (optional) ───────────────────────────────────────
# Your Pocket Option session ID (from browser cookies, key: "ssid").
# If left empty, the WebSocket module is skipped and technical signals
# are not generated (fundamentals + news + social still work).
POCKET_SSID=

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# Seconds between full scan cycles (default: 900 = 15 minutes)
SCAN_INTERVAL_SECONDS=900

# Seconds to suppress duplicate signals for the same asset (default: 60)
SIGNAL_COOLDOWN_SECONDS=60
