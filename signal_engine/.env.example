# ─────────────────────────────────────────────────────────────────────────────
# Fundamental OTC Signal Engine – Environment Variables
# Copy to .env and fill in your real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram (Telethon user login) ───────────────────────────────────────────
# Get API credentials from https://my.telegram.org/apps
TG_API_ID=31034570
TG_API_HASH=your_api_hash_here
TG_PHONE=+256780224449

# Where to send signal alerts. "me" = your own Saved Messages.
TG_MY_CHAT_ID=me

# ── Data API Keys ─────────────────────────────────────────────────────────────
# Finnworlds Macroeconomic Calendar – https://finnworlds.com
FINNWORLDS_API_KEY=your_finnworlds_key_here

# NewsAPI – https://newsapi.org (free tier: 100 requests/day)
NEWS_API_KEY=your_newsapi_key_here

# ── Optional tuning ───────────────────────────────────────────────────────────
# How often to run a scan cycle, in seconds (default: 900 = 15 minutes)
SCAN_INTERVAL_SECONDS=900

# How long to suppress duplicate signals for the same instrument (default: 3600 = 1 hour)
COOLDOWN_SECONDS=3600
