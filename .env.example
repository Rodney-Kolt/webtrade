# ─────────────────────────────────────────────────────────────────────────────
# Telegram Signal Assistant – Environment Variables
# Copy this file to .env (never commit .env to version control).
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Telegram API credentials (get from https://my.telegram.org/apps)
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# Your Telegram phone number in international format
TG_PHONE=+15551234567

# Comma-separated list of channel/group usernames or numeric IDs to monitor.
# Examples: "signalschannel,@another_channel,-1001234567890"
TG_CHANNELS=signalschannel,-1001234567890

# Where to forward matched signals.
# Use "me" for your own Saved Messages, or a numeric chat/group ID.
TG_MY_CHAT_ID=me

# ── Optional (safety filters) ─────────────────────────────────────────────────

# Minimum payout percentage to accept a signal (default: 70).
# Signals that include a payout value below this are discarded.
PAYOUT_THRESHOLD=70

# Seconds to suppress duplicate signals for the same asset/direction/timeframe
# (default: 60).
COOLDOWN_SECONDS=60

# UTC trading window. Leave both empty to allow signals at any time.
# Format: HH:MM  (24-hour clock, UTC)
TRADING_HOURS_START=08:00
TRADING_HOURS_END=22:00

# Comma-separated list of asset pairs to ignore entirely.
# Example: "XAU/USD,BTC/USD,ETH/USD"
BLACKLISTED_ASSETS=XAU/USD,BTC/USD
